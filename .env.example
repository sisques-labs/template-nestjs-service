  PORT=3000                                                                                                                                                                                                 
  APP_NAME=your-service-name                                                                                                                                                                                
  # error | warn | info | http | verbose | debug | silly                                                                                                                                                    
  LOG_LEVEL=info                                                                                                                                                                                            
                                                                                                                                                                                                            
  MONGODB_URI=mongodb://localhost:27017
  MONGODB_DATABASE=your-service-name                                                                                                                                                                        
                                                                  
  # Comma-separated brokers (e.g. localhost:9092). Leave empty to run without Kafka.
  KAFKA_BROKERS=
  KAFKA_CLIENT_ID=your-service-name
  KAFKA_CONSUMER_GROUP_ID=your-service-name-consumer                                                                                                                                                        
  SCHEMA_REGISTRY_HOST=http://localhost:8081